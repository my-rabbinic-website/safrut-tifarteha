    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });

        // Database
        const products = [
            { id: 1, category: "תורה", nameHE: "ספר תורה אשכנזי 'בית יוסף'", nameEN: "Ashkenazi Torah Scroll", priceUSD: 48000, priceILS: 175000, img: "https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=800", descHE: "ספר תורה מהודר בתכלית ההידור. נכתב ע\"י סופר ירא שמים בעל תעודה בתוקף, על גבי קלף שליל בעבודת יד. כולל 3 הגהות מלאות (מחשב ואדם).", descEN: "Premium Ashkenazi Torah scroll written by a certified scribe on handmade parchment. Includes 3 rigorous inspections." },
            { id: 2, category: "תורה", nameHE: "ספר תורה ספרדי 'ולאדי'", nameEN: "Sephardic Torah Scroll", priceUSD: 45000, priceILS: 165000, img: "https://images.unsplash.com/photo-1544928147-79a2dbc1f389?q=80&w=800", descHE: "כתיבה מסורתית ומרהיבה בנוסח עדות המזרח, תיוג מושלם ברמת אמן, כולל ליווי הלכתי צמוד מראשית הכתיבה ועד סיומה.", descEN: "Traditional Sephardic writing with perfect tagging. Includes personal halachic guidance." },
            { id: 3, category: "תפילין", nameHE: "תפילין 'תפארת' עור אחד", nameEN: "Premium Tefillin (Ohr Ehad)", priceUSD: 2800, priceILS: 10500, img: "https://images.unsplash.com/photo-1510131436400-c02058448530?q=80&w=800", descHE: "תפילין מבהמה גסה, חרוצות ופרודות עד התפר. פרשיות מהודרות ביותר, רצועות עבודת יד מושחרות משני הצדדים.", descEN: "High-end Tefillin made from a single piece of thick leather, with exquisite internal parchments." },
            { id: 4, category: "מזוזות", nameHE: "מזוזה 'כתב המלך' 15 ס\"מ", nameEN: "Premium Mezuzah 15cm", priceUSD: 210, priceILS: 780, img: "https://images.unsplash.com/photo-1603566023308-4171d1e44280?q=80&w=800", descHE: "המידה הקלאסית המומלצת לכל פתחי הבית. הגהה כפולה, כתיבה רגועה ואחידה להפליא.", descEN: "Classic 15cm Mezuzah, highly recommended for standard doorposts. Double inspected." },
            { id: 5, category: "מגילות", nameHE: "מגילת אסתר 'המלך' אמנותית", nameEN: "Artisan Esther Scroll", priceUSD: 3500, priceILS: 12800, img: "https://images.unsplash.com/photo-1519681393784-d120267933ba?q=80&w=800", descHE: "מגילת 28 שורות בכתב מרהיב וסימטרי. יצירת אומנות אמיתית שנשמרת לדורות בבית המשפחה.", descEN: "A 28-line artistic Megillah written with incredible symmetry. A true family heirloom." },
            { id: 6, category: "מזוזות", nameHE: "מזוזה 'היכל' 20 ס\"מ", nameEN: "Grand Mezuzah 20cm", priceUSD: 350, priceILS: 1300, img: "https://images.unsplash.com/photo-1603566023308-4171d1e44280?q=80&w=800", descHE: "מזוזה גדולה ומרשימה המיועדת בעיקר לפתחי הבית המרכזיים ולשערי הכניסה. בולטת ביופייה ובהדרה.", descEN: "A large, impressive Mezuzah designed for main entrances and significant doorways." }
        ];

        let cart = [];
        let currentFilter = 'all';
        let currentCurrency = 'usd'; 
        let currentLang = 'he'; 

        window.addEventListener('scroll', () => {
            const header = document.getElementById('nav-header');
            const topBar = document.getElementById('top-bar');
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
                topBar.style.transform = 'translateY(-100%)';
                header.style.top = '15px';
            } else {
                header.classList.remove('scrolled');
                topBar.style.transform = 'translateY(0)';
                header.style.top = '';
            }
        });

        function setLang(lang) {
            currentLang = lang;
            document.documentElement.dir = lang === 'he' ? 'rtl' : 'ltr';
            
            document.querySelectorAll('[id^="lang-"]').forEach(el => el.classList.remove('active'));
            document.getElementById('lang-' + lang).classList.add('active');

            document.querySelectorAll('[data-he]').forEach(el => {
                if(el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                    el.placeholder = el.getAttribute(`data-${lang}`);
                } else {
                    el.innerHTML = el.getAttribute(`data-${lang}`);
                }
            });

            renderCatalog();
            updateCart();
        }

        function setCurrency(cur) {
            currentCurrency = cur;
            document.querySelectorAll('[id^="cur-"]').forEach(el => el.classList.remove('active'));
            document.getElementById('cur-' + cur).classList.add('active');
            renderCatalog();
            updateCart();
        }

        function getPrice(p) { return currentCurrency === 'usd' ? p.priceUSD : p.priceILS; }
        function formatPrice(amount) { return currentCurrency === 'usd' ? '$' + amount.toLocaleString() : '₪' + amount.toLocaleString(); }
        function getName(p) { return currentLang === 'he' ? p.nameHE : p.nameEN; }
        function getDesc(p) { return currentLang === 'he' ? p.descHE : p.descEN; }

        function renderCatalog() {
            const grid = document.getElementById('product-grid');
            const filtered = currentFilter === 'all' ? products : products.filter(p => p.category === currentFilter);
            
            grid.innerHTML = filtered.map(p => `
                <div class="premium-card group rounded-[2rem] p-6 flex flex-col" data-aos="fade-up" onclick="openModal(${p.id})">
                    <div class="relative overflow-hidden rounded-2xl mb-6 aspect-square">
                        <img src="${p.img}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" alt="${getName(p)}">
                        <div class="absolute inset-0 bg-black/5 group-hover:bg-black/10 transition-colors"></div>
                        <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-md px-3 py-1 rounded-full text-[8px] font-black font-sans uppercase tracking-widest text-luxury-gold border border-luxury-gold/20 shadow-sm">
                            ${p.category}
                        </div>
                        <div class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur-md text-center py-2.5 rounded-xl opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                            <span class="text-[9px] font-black uppercase tracking-widest font-sans text-luxury-dark">${currentLang === 'he' ? 'לחץ לתצוגה מהירה' : 'Quick View'}</span>
                        </div>
                    </div>
                    <div class="flex-1 text-right rtl:text-right ltr:text-left px-1">
                        <div class="flex justify-between items-start mb-3">
                            <span class="text-xl font-black font-sans gold-gradient">${formatPrice(getPrice(p))}</span>
                        </div>
                        <h3 class="text-lg font-bold font-tradition italic text-luxury-dark">${getName(p)}</h3>
                    </div>
                </div>
            `).join('');
        }

        function filterCatalog(cat) {
            currentFilter = cat;
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.replace('text-luxury-dark', 'text-gray-400');
                btn.classList.replace('border-luxury-gold', 'border-transparent');
            });
            const active = document.getElementById('btn-' + cat);
            if(active) {
                active.classList.replace('text-gray-400', 'text-luxury-dark');
                active.classList.replace('border-transparent', 'border-luxury-gold');
            }
            renderCatalog();
        }

        function openModal(pid) {
            const p = products.find(x => x.id === pid);
            document.getElementById('modal-img').src = p.img;
            document.getElementById('modal-cat').innerText = p.category;
            document.getElementById('modal-title').innerText = getName(p);
            document.getElementById('modal-price').innerText = formatPrice(getPrice(p));
            document.getElementById('modal-desc').innerText = getDesc(p);
            document.getElementById('modal-add-btn').onclick = () => {
                addToCart(p.id);
                closeModal();
            };
            document.getElementById('product-modal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('product-modal').classList.remove('active');
            document.body.style.overflow = '';
        }

        function addToCart(pid) {
            cart.push(products.find(p => p.id === pid));
            updateCart();
            toggleCart(true); 
        }

        function removeFromCart(idx) {
            cart.splice(idx, 1);
            updateCart();
        }

        function updateCart() {
            const list = document.getElementById('cart-items');
            const checkList = document.getElementById('checkout-list');
            const totalEl = document.getElementById('cart-total');
            const finalEl = document.getElementById('final-total');
            document.getElementById('cart-count').innerText = cart.length;

            if(cart.length === 0) {
                list.innerHTML = `<div class="flex flex-col items-center justify-center py-20 text-gray-400 italic"><p class="text-sm">${currentLang==='he' ? 'הסל ריק כרגע' : 'Cart is empty'}</p></div>`;
                checkList.innerHTML = `<p class="text-gray-500 text-sm italic">${currentLang==='he' ? 'אין פריטים בסל' : 'No items yet'}</p>`;
                totalEl.innerText = formatPrice(0);
                finalEl.innerText = formatPrice(0);
                finalEl.setAttribute('data-usd', '0');
                return;
            }

            let totalUSD = 0; let totalILS = 0;
            list.innerHTML = cart.map((item, idx) => {
                totalUSD += item.priceUSD; totalILS += item.priceILS;
                return `
                    <div class="flex items-center gap-4 bg-luxury-cream p-4 rounded-2xl border border-luxury-gold/10">
                        <img src="${item.img}" class="w-14 h-14 object-cover rounded-xl shadow-sm">
                        <div class="flex-1 text-right rtl:text-right ltr:text-left">
                            <h4 class="text-xs font-bold font-tradition italic text-luxury-dark mb-1">${getName(item)}</h4>
                            <p class="text-[11px] font-black font-sans gold-gradient">${formatPrice(getPrice(item))}</p>
                        </div>
                        <button onclick="removeFromCart(${idx})" class="text-gray-300 hover:text-red-500 transition-colors p-2 bg-white rounded-full shadow-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                `;
            }).join('');

            checkList.innerHTML = cart.map(item => `
                <div class="flex justify-between items-center text-xs border-b border-white/10 pb-3">
                    <span class="text-gray-300 font-serif italic truncate pr-2">${getName(item)}</span>
                    <span class="font-black font-sans text-luxury-gold whitespace-nowrap">${formatPrice(getPrice(item))}</span>
                </div>
            `).join('');

            const finalAmount = currentCurrency === 'usd' ? totalUSD : totalILS;
            totalEl.innerText = formatPrice(finalAmount);
            finalEl.innerText = formatPrice(finalAmount);
            finalEl.setAttribute('data-usd', totalUSD); 
        }

        function toggleCart(forceOpen = false) {
            const d = document.getElementById('cart-drawer');
            const o = document.getElementById('cart-overlay');
            const isOpen = d.classList.contains('translate-x-0');
            
            if(!isOpen || forceOpen) {
                d.classList.replace('translate-x-[-100%]', 'translate-x-0');
                o.classList.remove('hidden');
                setTimeout(() => o.style.opacity = '1', 10);
                document.body.style.overflow = 'hidden';
            } else {
                d.classList.replace('translate-x-0', 'translate-x-[-100%]');
                o.style.opacity = '0';
                setTimeout(() => o.classList.add('hidden'), 500);
                document.body.style.overflow = '';
            }
        }

        function toggleMenu(show) {
            const m = document.getElementById('mobile-menu');
            const o = document.getElementById('mobile-overlay');
            if(show) {
                m.classList.add('active');
                o.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            } else {
                m.classList.remove('active');
                o.classList.add('hidden');
                document.body.style.overflow = '';
            }
        }

        function scrollToAndFilter(cat) {
            filterCatalog(cat);
            document.getElementById('products').scrollIntoView({behavior:'smooth'});
        }

        function goToCheckout() {
            toggleCart();
            document.getElementById('checkout').scrollIntoView({behavior:'smooth'});
        }

        function processOrder() {
            const totalUSD = document.getElementById('final-total').getAttribute('data-usd');
            if(totalUSD == "0") {
                alert(currentLang === 'he' ? "הסל שלך ריק. אנא בחר פריטים." : "Cart is empty. Please add items.");
                return;
            }
            const name = document.getElementById('full-name').value;
            const address = document.getElementById('address').value;
            
            if(!name || !address) {
                alert(currentLang === 'he' ? "אנא וודא ששם מלא וכתובת למשלוח מוזנים כראוי." : "Please fill in all shipping details.");
                return;
            }
            
            window.location.href = `https://paypal.me/Tifarteha/${totalUSD}USD`;
        }

        function processCreditCard() {
            const totalUSD = document.getElementById('final-total').getAttribute('data-usd');
            if(totalUSD == "0") {
                alert(currentLang === 'he' ? "הסל שלך ריק. אנא בחר פריטים." : "Cart is empty. Please add items.");
                return;
            }
            const name = document.getElementById('full-name').value;
            const address = document.getElementById('address').value;
            
            if(!name || !address) {
                alert(currentLang === 'he' ? "אנא וודא ששם מלא וכתובת למשלוח מוזנים כראוי לפני המעבר לתשלום באשראי." : "Please fill in all shipping details before proceeding to credit card payment.");
                return;
            }
            
            alert(currentLang === 'he' ? "מעביר למסוף סליקת אשראי מאובטח..." : "Redirecting to secure credit card gateway...");
            // Here you would integrate your actual Credit Card gateway (e.g., Stripe, Tranzila, Pelepay)
        }

        const locationsHE = ["ניו יורק", "לונדון", "מיאמי", "פריז", "לוס אנג'לס", "ירושלים", "תל אביב", "אנטוורפן"];
        const locationsEN = ["New York", "London", "Miami", "Paris", "Los Angeles", "Jerusalem", "Tel Aviv", "Antwerp"];
        
        function showLiveToast() {
            const toast = document.getElementById('live-toast');
            const locs = currentLang === 'he' ? locationsHE : locationsEN;
            const loc = locs[Math.floor(Math.random() * locs.length)];
            const prod = products[Math.floor(Math.random() * products.length)];
            const prodName = currentLang === 'he' ? prod.nameHE : prod.nameEN;
            const verb = currentLang === 'he' ? "רכש כעת" : "just purchased";
            
            document.getElementById('live-toast-text').innerText = currentLang === 'he' ? 
                `לקוח מ${loc} ${verb} ${prodName}` : 
                `A customer from ${loc} ${verb} ${prodName}`;
            
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 5000);
        }

        window.onload = () => {
            setLang('he'); 
            setCurrency('usd'); 
            
            setTimeout(() => {
                showLiveToast();
                setInterval(showLiveToast, 35000);
            }, 8000);
        };
    </script>
</body>
</html>
