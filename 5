        .gallery-item:hover { transform: translateY(-10px); box-shadow: 0 40px 80px rgba(0,0,0,0.25); z-index: 10; }
        .gallery-item img { transition: transform 2s cubic-bezier(0.16, 1, 0.3, 1); }
        .gallery-item:hover img { transform: scale(1.08); }
        .gallery-overlay {
            position: absolute; inset: 0; background: linear-gradient(to top, rgba(5,5,5,0.95) 0%, rgba(5,5,5,0.3) 50%, transparent 100%);
            opacity: 0.85; transition: opacity 0.5s ease; display: flex; flex-direction: column; justify-content: flex-end; padding: 3.5rem;
        }
        .gallery-item:hover .gallery-overlay { opacity: 1; }

        /* Urgency Pulse */
        .stock-pulse {
            display: inline-flex; align-items: center; gap: 10px; padding: 6px 18px;
            background: rgba(220, 38, 38, 0.05); border: 1px solid rgba(220, 38, 38, 0.15);
            color: #b91c1c; border-radius: 20px; font-size: 13px; font-weight: 800; letter-spacing: 0.1em;
        }
        .stock-pulse .dot {
            width: 8px; height: 8px; background: #dc2626; border-radius: 50%;
            animation: pulse-red 2s infinite cubic-bezier(0.16, 1, 0.3, 1);
        }
        @keyframes pulse-red { 0% { box-shadow: 0 0 0 0 rgba(220,38,38,0.5); } 70% { box-shadow: 0 0 0 10px rgba(220,38,38,0); } 100% { box-shadow: 0 0 0 0 rgba(220,38,38,0); } }

        /* Floating Action Buttons */
        .fab-container { position: fixed; bottom: 40px; right: 40px; z-index: 999; display: flex; flex-direction: column; gap: 20px; }
        html[dir="ltr"] .fab-container { right: auto; left: 40px; }
        
        .whatsapp-fab, #scroll-top {
            background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(15px);
            border: 1px solid rgba(212, 175, 55, 0.5);
            width: 70px; height: 70px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.15), inset 0 0 20px rgba(255,255,255,0.8);
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); cursor: none; color: var(--luxury-gold);
        }
        .whatsapp-fab:hover, #scroll-top:hover { transform: scale(1.1) translateY(-8px); background: var(--luxury-gold); color: white; box-shadow: 0 25px 60px rgba(212, 175, 55, 0.35); border-color: transparent; }
        
        #scroll-top { opacity: 0; transform: translateY(40px); pointer-events: none; }
        #scroll-top.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }

        .fade-in { animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    </style>
</head>
