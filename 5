            }
            .specs-grid { grid-template-columns: 1fr; gap: 1rem; }
        }

        /* Ethereal Glowing Orbs */
        .glowing-orb {
            position: absolute; border-radius: 50%; filter: blur(160px); opacity: 0.35;
            animation: orb-float 25s infinite alternate cubic-bezier(0.4, 0, 0.2, 1); z-index: 0; pointer-events: none;
        }
        @keyframes orb-float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(60px, -60px) scale(1.2); }
        }
        
        /* Gallery Editorial Grid */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 3rem;
            grid-auto-flow: dense;
        }
        @media (min-width: 1024px) {
            .gallery-grid .span-2 { grid-column: span 2; grid-row: span 2; }
        }
        .gallery-item {
            position: relative; overflow: hidden; border-radius: 2.5rem;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1); transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
