                </div>
            `).join('');

            const stockNum = Math.floor(Math.random() * 3) + 1;
            const stockTextHe = p.category === 'תורה' ? `נותרו ${stockNum} הזמנות פתוחות לשנה זו` : `נשארו ${stockNum} פריטים אחרונים במלאי`;
            const stockTextEn = p.category === 'תורה' ? `Only ${stockNum} commissions left this year` : `Only ${stockNum} items left in stock`;
            document.getElementById('modal-stock-text').innerText = currentLang === 'he' ? stockTextHe : stockTextEn;

            const btn = document.getElementById('modal-add-btn');
            
            if(p.category === 'תורה') {
                btn.querySelector('span').innerText = currentLang === 'he' ? 'לתיאום פגישת רכישה' : 'Schedule Consultation';
                btn.onclick = () => {
                    window.open('https://wa.me/972528219928', '_blank');
                    closeModal();
                };
            } else {
                btn.querySelector('span').innerText = currentLang === 'he' ? 'הוסף לסל המהודר' : 'Add to Premium Cart';
                btn.onclick = () => {
                    addToCart(p.id);
                    closeModal();
                };
            }

            document.getElementById('product-modal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('product-modal').classList.remove('active');
            document.body.style.overflow = '';
        }

        // Cart Management
        function addToCart(pid) {
            cart.push(products.find(p => p.id === pid));
            updateCart();
            toggleCart(true); 
        }

        function removeFromCart(idx) {
            cart.splice(idx, 1);
            updateCart();
        }

        function updateCart() {
            const list = document.getElementById('cart-items');
            const checkList = document.getElementById('checkout-list');
            const totalEl = document.getElementById('cart-total');
            const finalEl = document.getElementById('final-total');
            const progressEl = document.getElementById('shipping-progress');
            const msgEl = document.getElementById('shipping-msg');
            document.getElementById('cart-count').innerText = cart.length;

            if(cart.length === 0) {
                list.innerHTML = `<div class="flex flex-col items-center justify-center py-32 text-gray-400 italic font-serif"><p class="text-2xl">${currentLang==='he' ? 'הסל שלכם ריק כרגע' : 'Your cart is currently empty'}</p></div>`;
                checkList.innerHTML = `<p class="text-gray-400 text-2xl italic font-light text-center">${currentLang==='he' ? 'הסל ריק' : 'Cart is empty'}</p>`;
                totalEl.innerText = formatPrice(0);
                finalEl.innerText = formatPrice(0);
                finalEl.setAttribute('data-usd', '0');
                finalEl.setAttribute('data-ils', '0');
                progressEl.style.width = '0%';
                msgEl.innerText = currentLang === 'he' ? 'חסר עוד $500 למשלוח מאובטח חינם' : 'Add $500 for Free Insured Shipping';
                return;
            }

            let totalUSD = 0; let totalILS = 0;
            list.innerHTML = cart.map((item, idx) => {
                totalUSD += item.priceUSD; totalILS += item.priceILS;
                return `
                    <div class="flex items-center gap-8 bg-white p-6 rounded-3xl border border-gray-100 shadow-sm fade-in">
                        <img src="${item.img}" class="w-24 h-24 object-cover rounded-2xl border border-gray-50" alt="${getName(item)}">
                        <div class="flex-1 text-right rtl:text-right ltr:text-left">
                            <h4 class="text-xl font-bold font-tradition italic text-luxury-dark mb-3">${getName(item)}</h4>
                            <p class="text-2xl font-light font-sans text-luxury-dark">${formatPrice(getPrice(item))}</p>
                        </div>
                        <button onclick="removeFromCart(${idx})" class="w-12 h-12 rounded-full bg-[#FAFAFA] flex items-center justify-center text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors border border-gray-100 hover-trigger">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                `;
            }).join('');

            checkList.innerHTML = cart.map(item => `
                <div class="flex justify-between items-center text-xl border-b border-gray-100 pb-8 pt-6 fade-in">
                    <span class="text-gray-600 font-serif italic truncate pr-4">${getName(item)}</span>
                    <span class="font-bold font-sans text-luxury-dark whitespace-nowrap">${formatPrice(getPrice(item))}</span>
                </div>
            `).join('');

            const finalAmount = currentCurrency === 'usd' ? totalUSD : totalILS;
            totalEl.innerText = formatPrice(finalAmount);
            finalEl.innerText = formatPrice(finalAmount);
            finalEl.setAttribute('data-usd', totalUSD); 
            finalEl.setAttribute('data-ils', totalILS); 
            
            const targetUSD = 500;
            const targetILS = 1850;
            const target = currentCurrency === 'usd' ? targetUSD : targetILS;
            const symbol = currentCurrency === 'usd' ? '$' : '₪';
            
            if (finalAmount >= target) {
                progressEl.style.width = '100%';
                progressEl.classList.add('bg-[#34A853]');
                progressEl.classList.remove('bg-luxury-gold');
                msgEl.innerText = currentLang === 'he' ? 'זכאי למשלוח בינלאומי מאובטח חינם!' : 'Eligible for Free Insured Global Delivery!';
                msgEl.classList.replace('text-luxury-goldLight', 'text-[#34A853]');
            } else {
                const percent = (finalAmount / target) * 100;
                progressEl.style.width = `${percent}%`;
                progressEl.classList.remove('bg-[#34A853]');
                progressEl.classList.add('bg-luxury-gold');
                msgEl.classList.replace('text-[#34A853]', 'text-luxury-goldLight');
                const diff = target - finalAmount;
                msgEl.innerText = currentLang === 'he' ? `חסר עוד ${symbol}${diff.toLocaleString()} למשלוח חינם` : `Add ${symbol}${diff.toLocaleString()} for Free Shipping`;
            }
        }

        // Express Checkout Engine with TZQ8K3PLELXLS
        function processOrder(method) {
            const totalUSD = document.getElementById('final-total').getAttribute('data-usd');
            const totalILS = document.getElementById('final-total').getAttribute('data-ils');
            
            if(totalUSD == "0") {
                showSystemToast(currentLang === 'he' ? "הסל ריק. אנא בחר מוצרים מהקטלוג." : "Cart is empty. Please select products.", true);
                return;
            }

            const btnId = method === 'paypal' ? 'btn-paypal' : 'btn-credit';
            const btn = document.getElementById(btnId);
            const originalHtml = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = `<svg class="animate-spin h-8 w-8 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;
            
            const amount = currentCurrency === 'usd' ? totalUSD : totalILS;
            const currencyStr = currentCurrency === 'usd' ? 'USD' : 'ILS';

            setTimeout(() => {
                if (method === 'paypal') {
                    // PayPal Form submission using the specific Merchant ID
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = 'https://www.paypal.com/cgi-bin/webscr';
                    
                    const params = {
                        cmd: '_xclick',
                        business: 'TZQ8K3PLELXLS', // Merchant ID Implementation
                        item_name: currentLang === 'he' ? 'רכישה מספרות תפארתך' : 'Purchase from Sifrut Tifarteha',
                        amount: amount,
                        currency_code: currencyStr,
                        charset: 'utf-8'
                    };
                    
                    for (const key in params) {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = key;
                        input.value = params[key];
                        form.appendChild(input);
                    }
                    
                    document.body.appendChild(form);
                    form.submit();
                } else {
                    showSystemToast(currentLang === 'he' ? "מעביר למסוף האשראי..." : "Redirecting to credit card gateway...");
                    setTimeout(() => {
                        window.location.href = `https://paypal.me/Tifarteha/${amount}${currencyStr}`;
                        btn.disabled = false;
                        btn.innerHTML = originalHtml;
                    }, 1000);
                }
            }, 800);
        }

        // Live Social Proof Engine
        const locationsHE = ["ניו יורק", "לונדון", "מיאמי", "פריז", "לוס אנג'לס", "ירושלים", "תל אביב", "אנטוורפן", "טורונטו", "פנמה"];
        const locationsEN = ["New York", "London", "Miami", "Paris", "Los Angeles", "Jerusalem", "Tel Aviv", "Antwerp", "Toronto", "Panama"];
        
        function showLiveToast() {
            const toast = document.getElementById('live-toast');
            if(toast.classList.contains('opacity-100')) return;

            const locs = currentLang === 'he' ? locationsHE : locationsEN;
            const loc = locs[Math.floor(Math.random() * locs.length)];
            const prod = products.filter(p => p.category !== 'תורה')[Math.floor(Math.random() * (products.length - 2))]; 
            const prodName = currentLang === 'he' ? prod.nameHE : prod.nameEN;
            const verb = currentLang === 'he' ? "רכש כעת" : "just purchased";
            
            document.getElementById('live-toast-text').innerText = currentLang === 'he' ? 
                `לקוח מ${loc} ${verb} ${prodName}` : 
                `A customer from ${loc} ${verb} ${prodName}`;
            
            toast.classList.replace('opacity-0', 'opacity-100');
            setTimeout(() => toast.classList.replace('opacity-100', 'opacity-0'), 7000);
        }

        // Initialization
        window.onload = () => {
            setLang('he'); 
            setCurrency('usd'); 
            
            setTimeout(() => {
                showLiveToast();
                setInterval(showLiveToast, 35000);
            }, 8000);
        };
    </script>
</body>
</html>
