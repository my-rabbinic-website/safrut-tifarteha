                height: 92dvh; max-height: 92dvh; 
                border-radius: 2.5rem 2.5rem 0 0; 
                display: flex; flex-direction: column; 
                transform: translateY(100%);
                margin-top: auto;
            }
            #product-modal.active .modal-content { transform: translateY(0); }
            .modal-scroll-area { flex: 1; overflow-y: auto; padding-bottom: 140px; }
            .modal-action-bar {
                position: absolute; bottom: 0; left: 0; width: 100%; background: rgba(255,255,255,0.98); backdrop-filter: blur(20px);
