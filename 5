        html[dir="ltr"] #mobile-menu { transform: translateX(-100%); right: auto; left: 0; }
        #mobile-menu.active { transform: translateX(0); }

        /* Modals & Toasts */
        #product-modal { transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.5s; }
        #product-modal .modal-content { transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); transform: scale(0.95) translateY(20px); }
        #product-modal.active { opacity: 1; visibility: visible; }
        #product-modal.active .modal-content { transform: scale(1) translateY(0); }
        
        /* Detailed Spec Grid */
        .specs-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }
        .spec-item {
            background: #ffffff;
            border: 1px solid rgba(0,0,0,0.05);
            padding: 1rem 1.5rem;
