            left: 1rem;
            border: 1px solid rgba(212, 175, 55, 0.25);
        }
        @media (max-width: 768px) {
            header.scrolled { width: 95%; left: 2.5%; }
        }

        /* Animated Metallic Gold Foil */
        .gold-gradient {
            background: linear-gradient(110deg, #C59B43 0%, #FDF7C3 25%, #D4AF37 50%, #FDF7C3 75%, #C59B43 100%);
            background-size: 200% auto;
            color: #000;
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine 10s linear infinite;
        }
        @keyframes shine { to { background-position: 200% center; } }

        /* Sweep Shine Button */
        .btn-shine {
            position: relative;
            overflow: hidden;
            z-index: 1;
        }
        .btn-shine::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0) 100%);
            transform: skewX(-25deg); animation: sweep-shine 6s infinite; z-index: -1;
        }
        @keyframes sweep-shine { 0% { left: -100%; } 20%, 100% { left: 200%; } }

        /* Museum-Style Product Cards */
        .premium-card {
            background: #ffffff;
            border: 1px solid rgba(0,0,0,0.04);
            border-radius: 2rem;
            transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
            overflow: hidden; cursor: none; position: relative;
        }
        .premium-card:hover {
            transform: translateY(-15px);
            border-color: rgba(212, 175, 55, 0.6);
            box-shadow: 0 50px 100px -20px rgba(212, 175, 55, 0.3), 0 0 50px rgba(212, 175, 55, 0.15);
            z-index: 10;
        }
        .premium-card::before {
            content: ''; position: absolute; inset: 0;
            background: radial-gradient(circle at top right, rgba(212,175,55,0.1), transparent 70%);
            opacity: 0; transition: opacity 0.7s ease; pointer-events: none;
        }
        .premium-card:hover::before { opacity: 1; }

        .product-ribbon {
            position: absolute; top: 30px; left: -45px;
            background: linear-gradient(135deg, #D4AF37, #996515);
            color: white; padding: 8px 55px; transform: rotate(-45deg);
            font-size: 11px; font-weight: 800; font-family: 'Assistant', sans-serif;
            text-transform: uppercase; letter-spacing: 0.3em; z-index: 10;
            box-shadow: 0 5px 20px rgba(212,175,55,0.4);
        }
        html[dir="ltr"] .product-ribbon { left: auto; right: -45px; transform: rotate(45deg); }

        /* Quick View Hover Overlay */
        .quick-view-overlay {
            background: rgba(5, 5, 5, 0.4);
            backdrop-filter: blur(4px);
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        .premium-card:hover .quick-view-overlay { opacity: 1; }
        .quick-view-btn {
            transform: translateY(20px);
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
