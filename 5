            a, button, input, textarea, .premium-card { cursor: none; }
        }
        .custom-cursor {
            position: fixed; top: 0; left: 0; width: 36px; height: 36px;
            border: 1.5px solid var(--gold); border-radius: 50%;
            pointer-events: none; z-index: 99999;
